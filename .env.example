# ─── LLM Provider ────────────────────────────────────────────────
# Options: "groq" | "qwen_local_3b" | "qwen_local_7b"
LLM_PROVIDER=qwen_local_3b

# ─── Groq API (required when LLM_PROVIDER=groq) ─────────────────
# Get a free key at https://groq.com/
GROQ_API_KEY=gsk_your_key_here

# Optional: override default model choices
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_FAST_MODEL=llama-3.1-8b-instant

# ─── Local Qwen models (optional) ───────────────────────────────
# Override default GGUF paths if models are stored elsewhere
# LOCAL_LLM_3B_PATH=models/qwen/qwen2.5-3b-instruct-q5_k_m.gguf
# LOCAL_LLM_7B_PATH=models/qwen/qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf

# ─── Zoom integration (optional) ────────────────────────────────
# Create a Server-to-Server OAuth app at https://marketplace.zoom.us/
# ZOOM_ACCOUNT_ID=your_account_id
# ZOOM_CLIENT_ID=your_client_id
# ZOOM_CLIENT_SECRET=your_client_secret
